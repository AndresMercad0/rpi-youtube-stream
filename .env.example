# =============================================================================
# rpi-youtube-stream - Variables de entorno opcionales
# =============================================================================
# Copia este archivo a .env si necesitas sobreescribir algun valor por defecto.
# El servicio systemd lo carga automaticamente si existe (no es obligatorio).
#
#   cp .env.example .env
#
# Normalmente install.sh crea este archivo por ti (te pide las credenciales).
# Si lo creas a mano, lo unico obligatorio son las dos credenciales OAuth.

# --- Credenciales OAuth (OBLIGATORIAS) ---
# Del cliente de tipo "TV and Limited Input devices" (ver SETUP-GOOGLE.md).
# El stream se crea solo por API; no hace falta stream key.
YT_CLIENT_ID=xxxxx.apps.googleusercontent.com
YT_CLIENT_SECRET=xxxxx

# --- Servidor (opcional) ---
# PORT=8082

# --- Marca / textos (opcional) ---
# BRAND_NAME=Transmision en vivo
# DEFAULT_STREAM_TITLE=Transmision en vivo

# --- Hardware (solo si tu Pi difiere del default) ---
# VIDEO_BIN=rpicam-vid           # Se auto-detecta (rpicam-vid o libcamera-vid)
# AUDIO_DEVICE=plughw:0,0        # Revisa con: arecord -l
# PREVIEW_FBDEV=/dev/fb0         # Framebuffer de la LCD (se auto-detecta)
# PREVIEW_SCALE=480:320          # Resolucion del preview (se auto-detecta del fb)
# PREVIEW_PIXFMT=rgb565le        # Formato del framebuffer (16bpp=rgb565le, 32bpp=bgra)
# PREVIEW_FPS=15                 # FPS del preview en la LCD
